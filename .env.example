# Copier ce fichier en .env et renseigner les valeurs
# NE PAS committer .env dans git

# Google Places API (collecteur concurrence SAP)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Répertoire de stockage des études (défaut : storage/ local)
# STELLA_STORAGE_DIR=/data/studies

# Webhook secret — Bearer token vérifié sur POST /generate-study (appelé par le front wizard)
# Doit correspondre à WEBHOOK_SECRET côté front (process.env.WEBHOOK_SECRET)
WEBHOOK_SECRET=your_webhook_secret_here

# Callback backend → front après génération
# Secret utilisé par le backend pour appeler POST /api/public/generation-webhook
# Doit correspondre à GENERATION_WEBHOOK_SECRET côté front
GENERATION_WEBHOOK_SECRET=your_generation_webhook_secret_here
# URL du serveur front TanStack Start (pour le callback)
FRONT_WEBHOOK_URL=https://your-front-domain.com/api/public/generation-webhook

# CORS (liste de domaines séparés par des virgules, en plus du regex)
# CORS_ALLOW_ORIGINS=https://monapp.lovable.app

# Regex CORS (défaut : couvre *.lovable.app et *.lovableproject.com)
# CORS_ALLOW_ORIGIN_REGEX=https://.*\.(lovable\.app|lovableproject\.com)$
